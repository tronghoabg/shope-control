generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // DB dùng chung trên VPS (local + server cùng trỏ vào)
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  passwordHash  String? // null nếu đăng nhập bằng Google
  role          String    @default("user") // user | admin
  apiToken      String?   @unique // token cho extension gọi API (quota)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  aiCallsTotal  Int       @default(0) // tổng số lần gọi AI qua hệ thống (thống kê admin)
  aiTokensTotal Int       @default(0) // tổng token ước lượng đã tiêu
  bannedAt      DateTime? // chặn dùng AI hệ thống khi nghi lạm dụng (null = bình thường)

  accounts      Account[]
  sessions      Session[]
  subscription  Subscription?
  payments      Payment[]
  usage         DailyUsage[]
  posted        PostedComment[]
}

// ── Lịch sử đã đăng (comment/bài) — bền qua đổi máy/xoá cache, admin xem được ──
model PostedComment {
  id        String   @id @default(cuid())
  userId    String
  mode      String   @default("comment") // comment | post
  groupId   String?
  groupName String?
  postId    String?
  content   String   @db.Text
  link      String?
  permalink String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// ── Quota theo ngày (free 10 comment/ngày) ──
model DailyUsage {
  id       String @id @default(cuid())
  userId   String
  date     String // "YYYY-MM-DD" theo giờ VN
  comments Int    @default(0)
  aiCalls  Int    @default(0) // số lần gọi AI hệ thống trong ngày
  aiTokens Int    @default(0) // token ước lượng trong ngày
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

// ── Cấu hình hệ thống (key-value) — vd API key AI của admin ──
model Setting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

// ── Gói đăng ký ──
model Subscription {
  id        String   @id @default(cuid())
  userId    String   @unique
  plan      String   @default("free") // free | m1 | m6 | m12
  status    String   @default("active") // active | expired
  expiresAt DateTime? // null = free (không hết hạn)
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Thanh toán qua SePay ──
model Payment {
  id        String   @id @default(cuid())
  userId    String
  plan      String // m1 | m6 | m12
  amount    Int // VND
  code      String   @unique // nội dung CK để khớp (vd SHOPE<random>)
  status    String   @default("pending") // pending | paid | failed
  provider  String   @default("sepay")
  ref       String? // mã giao dịch SePay khi đã trả
  createdAt DateTime @default(now())
  paidAt    DateTime?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── NextAuth (Auth.js) ──
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

# DB — SQLite cho chạy local ngay (đổi sang Postgres khi deploy)
DATABASE_URL="file:./dev.db"

# Auth.js — sinh secret: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# Google OAuth (tạo ở https://console.cloud.google.com → OAuth client ID, web)
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# SePay — webhook gọi vào /api/sepay/webhook, đặt API key trùng với cấu hình SePay
SEPAY_WEBHOOK_APIKEY=""
# Tài khoản nhận tiền (hiện trên trang thanh toán)
SEPAY_BANK="MBBank"
SEPAY_ACCOUNT_NUMBER=""
SEPAY_ACCOUNT_NAME=""

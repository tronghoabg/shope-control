{
  "manifest_version": 3,
  "name": "ToolMKT AI — Tìm khách hàng trên Facebook",
  "version": "1.2",
  "description": "Trợ lý AI giúp tìm và phân tích bài đăng, nhóm Facebook có khách hàng tiềm năng; gợi ý nội dung tương tác phù hợp.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Mở ToolMKT AI (web app)"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "scripting",
    "tabs",
    "alarms",
    "notifications",
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": [
    "https://www.facebook.com/*",
    "https://web.facebook.com/*",
    "https://facebook.com/*",
    "https://m.facebook.com/*",
    "https://mbasic.facebook.com/*",
    "https://adsmanager.facebook.com/*",
    "https://business.facebook.com/*",
    "https://graph.facebook.com/*",
    "https://upload.facebook.com/*",
    "https://shopee.vn/*",
    "https://s.shopee.vn/*",
    "https://affiliate.shopee.vn/*",
    "https://toolmktai.com/*"
  ],
  "externally_connectable": {
    "matches": [
      "https://toolmktai.com/*"
    ]
  },
  "content_scripts": [
    {
      "matches": ["https://www.facebook.com/*", "https://web.facebook.com/*"],
      "js": ["inject.js"],
      "world": "MAIN",
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.facebook.com/*", "https://web.facebook.com/*"],
      "js": ["content_fb.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://shopee.vn/*"],
      "js": ["content_shopee.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://toolmktai.com/app/*"],
      "js": ["dashboard_bridge.js"],
      "run_at": "document_idle"
    }
  ]
}
